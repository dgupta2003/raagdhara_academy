rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Check if the caller is an admin (reads their users doc — cached by Firebase)
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // users/{uid} — own profile or admin
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    // students/{uid} — own record or admin
    match /students/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    // attendance — student reads own records, admin writes
    match /attendance/{id} {
      allow read: if request.auth != null
        && (resource.data.studentId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // payments — student reads own records, admin writes (webhook uses Admin SDK, bypasses rules)
    match /payments/{id} {
      allow read: if request.auth != null
        && (resource.data.studentId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // consultations — anyone can submit a booking; only admin can read/edit
    match /consultations/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // settings — any authenticated user can read; only admin can write
    match /settings/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
