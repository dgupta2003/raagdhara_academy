rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isParent() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent';
    }

    function getGuardianId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guardianId;
    }

    function parentOwnsStudent(studentId) {
      let guardianId = getGuardianId();
      return guardianId != null
        && get(/databases/$(database)/documents/guardians/$(guardianId)).data.studentIds.hasAny([studentId]);
    }

    // users/{uid} — own profile or admin
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    // students/{uid} — own record, admin, or linked parent
    match /students/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid
        || isAdmin()
        || (isParent() && parentOwnsStudent(uid))
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    // guardians/{uid} — own profile or admin
    match /guardians/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // attendance — student reads own, parent reads child's, admin writes
    match /attendance/{id} {
      allow read: if request.auth != null && (
        resource.data.studentId == request.auth.uid
        || isAdmin()
        || (isParent() && parentOwnsStudent(resource.data.studentId))
      );
      allow write: if isAdmin();
    }

    // payments — student reads own, parent reads child's, admin writes
    match /payments/{id} {
      allow read: if request.auth != null && (
        resource.data.studentId == request.auth.uid
        || isAdmin()
        || (isParent() && parentOwnsStudent(resource.data.studentId))
      );
      allow write: if isAdmin();
    }

    // consultations — anyone can submit a booking (public form), but constrain the
    // shape to block abuse of the unauthenticated write: only the known fields are
    // allowed, required fields must be present, and free-text is size-capped.
    // NOTE: this is a backstop, not full abuse protection — App Check / rate limiting
    // on the booking endpoint is still recommended.
    match /consultations/{id} {
      allow create: if
        request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'countryCode', 'ageGroup', 'course',
          'timezone', 'experience', 'goals', 'hearAbout', 'consultationType', 'createdAt'
        ])
        && request.resource.data.keys().hasAll(['name', 'email', 'phone', 'course', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100
        && request.resource.data.email is string && request.resource.data.email.size() <= 200
        && request.resource.data.phone is string && request.resource.data.phone.size() <= 40
        && request.resource.data.course is string && request.resource.data.course.size() <= 100
        && request.resource.data.createdAt is timestamp
        && (!('goals' in request.resource.data) || request.resource.data.goals == null
            || (request.resource.data.goals is string && request.resource.data.goals.size() <= 2000))
        && (!('hearAbout' in request.resource.data) || request.resource.data.hearAbout == null
            || (request.resource.data.hearAbout is string && request.resource.data.hearAbout.size() <= 500))
        && (!('experience' in request.resource.data) || request.resource.data.experience == null
            || (request.resource.data.experience is string && request.resource.data.experience.size() <= 500));
      allow read, update, delete: if isAdmin();
    }

    // settings — any authenticated user can read; only admin can write
    match /settings/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
